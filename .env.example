# Copy to .env and fill in your values

REDIS_URL=redis://localhost:6379
OPENBIS_URL=https://your-openbis-instance.example.com
BUFFER_DIR=./buffer
OSCILLOSCOPES_CONFIG=./config/oscilloscopes.yaml
LOCK_TTL_SECONDS=1800
HEALTH_CHECK_INTERVAL_SECONDS=5
# Health checks are skipped when no API request has arrived within this many seconds.
# Set to 0 to disable idle detection and always poll.
HEALTH_CHECK_IDLE_TIMEOUT_SECONDS=600
TOKEN_CACHE_SECONDS=60
EOD_RESET_TIMEZONE=Europe/Berlin

# --- Development / testing without external dependencies ---
#
# DEBUG=True enables a fully self-contained mode:
#   - Redis is replaced with an in-memory fake (no Redis process needed)
#   - All device drivers are replaced with MockOscilloscopeDriver
#   - Health monitor is skipped (devices show as ONLINE immediately)
#   - OpenBIS token validation is bypassed for DEBUG_TOKEN
#   - Dataset commits to OpenBIS return a simulated permId
#
# To start the API locally without any external services:
#   DEBUG=True uvicorn app.main:app --reload
#   curl -H "Authorization: Bearer debug-token" http://localhost:8000/auth/me
#
DEBUG=False
DEBUG_TOKEN=debug-token

# --- End-of-day OpenBIS equipment sync ---
# Bot account used by the nightly sync job to query EQUIPMENT objects.
# Leave blank to skip the sync job entirely (safe in development / DEBUG mode).
OPENBIS_BOT_USER=
OPENBIS_BOT_PASSWORD=
# Path to the YAML file that maps EQUIPMENT.ALTERNATIV_NAME to driver config.
DRIVER_MAPPING_CONFIG=./config/driver_mapping.yaml
# IP prefix filter for EQUIPMENT.IP_ADDRESS queries (supports trailing .* wildcard).
OPENBIS_EQUIPMENT_IP_FILTER=141.23.109.*
